{
  "name": "logrock",
  "version": "4.0.0",
  "description": "This module can help you build error tracking & crash reporting system for your React application.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node scripts.build --mode=production",
    "format": "npm run format:prettier && npm run format:code && npm run format:styles",
    "format:code": "eslint . --fix",
    "format:prettier": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:styles": "stylelint \"src/**/*.scss\" --fix",
    "lint": "npm run lint:ts && npm run lint:code && npm run lint:styles",
    "lint:code": "eslint .",
    "lint:commit": "commitlint -e",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "lint:ts": "tsc --noEmit",
    "pre-commit": "lint-staged",
    "test": "node scripts.tests.js",
    "test:watch": "node scripts.tests.js --watch",
    "production": "npm run lint && npm test && npm run build && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexSergey/logrock.git"
  },
  "author": "Aleksandrov Sergey <gooddev.sergey@gmail.com> (https://github.com/AlexSergey/logrock)",
  "license": "MIT",
  "homepage": "http://www.natrube.net/logrock/index.html",
  "bugs": {
    "url": "https://github.com/AlexSergey/logrock/issues"
  },
  "keywords": [
    "logger",
    "logging",
    "logs",
    "react",
    "react-log",
    "react-logger",
    "error-tracking",
    "crash-reporting",
    "react-component"
  ],
  "private": false,
  "dependencies": {
    "limited-array": "^2.0.3"
  },
  "devDependencies": {
    "@rockpack/codestyle": "7.2.0",
    "@rockpack/compiler": "7.2.0",
    "@rockpack/tester": "7.2.0",
    "@rockpack/tsconfig": "7.2.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.12.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "axios-mock-adapter": "2.1.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "source-map": "0.8.0-beta.0",
    "@types/jest": "^29.4.0"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  }
}
